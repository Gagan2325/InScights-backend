# Brandcare InScights — Server Environment Variables
# Copy this file to .env and fill in your keys

# ── REQUIRED
OPENAI_API_KEY=sk-your-openai-key-here

# ── OPTIONAL (increases PubMed rate limits from 3/sec to 10/sec)
PUBMED_API_KEY=your-ncbi-api-key-here
# Get a free key at: https://www.ncbi.nlm.nih.gov/account/

# ── SERVER CONFIG
PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# ── FUTURE: Data on File (when library feature is built)
# DOF_STORAGE_PATH=./data-on-file
# DOF_ENCRYPTION_KEY=your-256-bit-key
